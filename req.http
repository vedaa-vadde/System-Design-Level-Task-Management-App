content-Type: application/json

{
  "lists":[
    {
      "id":"LIST_ID_1",
      "order":1
    },
    {
      "id":"LIST_ID_2",
      "order":2
    }
  ]
}

###create card
POST http://localhost:5000/api/cards
Content-Type: application/json

{
  "title":"thinali",
  "description":"eat biryani w team",
  "listId":"LIST_ID",
  "boardId":"BOARD_ID",
  "status":"ongoing"
}

###get board cards
GET http://localhost:5000/api/cards/board/BOARD_ID

###get list cards
GET http://localhost:5000/api/cards/list/LIST_ID

###update card
PUT http://localhost:5000/api/cards/CARD_ID
Content-Type: application/json

{
   "title":"Updated Card",
  "status":"done"
}

###delete card
DELETE http://localhost:5000/api/cards/CARD_ID

###move card
PUT http://localhost:5000/api/cards/move/CARD_ID
Content-Type: application/json

{
   "newListId":"NEW_LIST_ID",
   "newOrder":2
}


###reorder cards
PUT http://localhost:5000/api/cards/reorder/all
Content-Type: application/json

{
  "cards":[
    {
      "id":"CARD_ID_1",
      "order":1
    },
    {
      "id":"CARD_ID_2",
      "order":2
    }
  ]
}